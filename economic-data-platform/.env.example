# =============================================================================
# ECONOMIC DATA PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API Keys - Crypto Data Sources
# -----------------------------------------------------------------------------
# Binance - No API key needed for public data (WebSocket)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CoinGecko - Free tier: 50 calls/min, Pro: Get key from https://www.coingecko.com/api
COINGECKO_API_KEY=

# CryptoCompare - Get key from https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=

# -----------------------------------------------------------------------------
# API Keys - US Economic Data Sources
# -----------------------------------------------------------------------------
# FRED - Get key from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BEA - Get key from https://apps.bea.gov/api/signup/
BEA_API_KEY=

# Census - Get key from https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS - Get key from https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# -----------------------------------------------------------------------------
# API Keys - International Data Sources (Most are free, no key needed)
# -----------------------------------------------------------------------------
# World Bank - No key needed
# IMF - No key needed
# OECD - No key needed

# -----------------------------------------------------------------------------
# Research Data Sources
# -----------------------------------------------------------------------------
# AEA ICPSR - Register at https://www.openicpsr.org/openicpsr/aea
AEA_ICPSR_USERNAME=
AEA_ICPSR_PASSWORD=

# IPUMS - Register at https://www.ipums.org/
IPUMS_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=economic_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=economic_data

# Connection string format
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# ClickHouse Database
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=economic_data

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# -----------------------------------------------------------------------------
# Apache Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Kafka Topics
KAFKA_TOPIC_CRYPTO_TRADES=crypto.trades
KAFKA_TOPIC_CRYPTO_PRICES=crypto.prices
KAFKA_TOPIC_ECONOMIC_DATA=economic.data

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Bucket names
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# -----------------------------------------------------------------------------
# Apache Spark
# -----------------------------------------------------------------------------
SPARK_MASTER_URL=spark://localhost:7077
SPARK_APP_NAME=economic-data-platform

# -----------------------------------------------------------------------------
# FastAPI Settings
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# CORS
API_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD=60

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key_here

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Domain & SSL (Production)
# -----------------------------------------------------------------------------
DOMAIN=localhost
SSL_ENABLED=false

# -----------------------------------------------------------------------------
# Data Ingestion Settings
# -----------------------------------------------------------------------------
# Crypto data refresh intervals (in seconds)
CRYPTO_REALTIME_ENABLED=true
CRYPTO_PRICE_REFRESH_INTERVAL=300  # 5 minutes
CRYPTO_OHLCV_REFRESH_INTERVAL=3600  # 1 hour

# Economic data refresh intervals
ECONOMIC_DAILY_REFRESH_HOUR=6  # 6 AM UTC
ECONOMIC_MONTHLY_REFRESH_DAY=1  # First day of month

# Batch sizes
BATCH_SIZE_CRYPTO=1000
BATCH_SIZE_ECONOMIC=500

# Rate limiting (requests per minute)
RATE_LIMIT_COINGECKO=50
RATE_LIMIT_FRED=120
RATE_LIMIT_WORLDBANK=60
