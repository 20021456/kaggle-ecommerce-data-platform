# =============================================================================
# Application Environment Variables for Dokploy
# =============================================================================
# Copy to .env and configure before deployment
# =============================================================================

# Domain
DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# Database Credentials (must match shared-databases)
# -----------------------------------------------------------------------------
POSTGRES_USER=economic_user
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_DB=economic_data

REDIS_PASSWORD=YOUR_REDIS_PASSWORD

MINIO_ACCESS_KEY=YOUR_MINIO_ACCESS
MINIO_SECRET_KEY=YOUR_MINIO_SECRET

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=GENERATE_JWT_SECRET_KEY_HERE

# -----------------------------------------------------------------------------
# API Keys - Economic Data
# -----------------------------------------------------------------------------
# FRED - https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# BEA - https://apps.bea.gov/api/signup/
BEA_API_KEY=your_bea_api_key

# BLS - https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key

# Census - https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key

# -----------------------------------------------------------------------------
# API Keys - Crypto Data
# -----------------------------------------------------------------------------
# CoinGecko Pro (optional)
COINGECKO_API_KEY=

# CryptoCompare - https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD
