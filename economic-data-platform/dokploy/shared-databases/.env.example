# =============================================================================
# Shared Databases Environment Variables
# =============================================================================
# Copy to .env and configure before deployment
# =============================================================================

# Domain (for Traefik routing)
DOMAIN=yourdomain.com

# PostgreSQL
POSTGRES_USER=economic_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=economic_data

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD
CLICKHOUSE_DB=economic_data

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# MinIO
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_MIN_8_CHARS
