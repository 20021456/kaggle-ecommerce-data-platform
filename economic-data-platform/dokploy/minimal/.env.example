# =============================================================================
# MINIMAL VPS Environment (2 vCPU, 4GB RAM)
# =============================================================================

# Domain
DOMAIN=yourdomain.com

# Microsoft SQL Server (Input Data Source)
MSSQL_HOST=45.124.94.158
MSSQL_PORT=1433
MSSQL_DATABASE=xomdata_dataset
MSSQL_USER=your_mssql_user
MSSQL_PASSWORD=your_mssql_password

# PostgreSQL
POSTGRES_USER=economic_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=economic_data

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# JWT (generate: openssl rand -hex 32)
JWT_SECRET_KEY=generate_a_32_char_secret_key_here

# API Keys (optional - app works without them with limited data)
FRED_API_KEY=
BEA_API_KEY=
BLS_API_KEY=
COINGECKO_API_KEY=

# Grafana (optional)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD
