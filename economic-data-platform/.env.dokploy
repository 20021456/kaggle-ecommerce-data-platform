# =============================================================================
# DOKPLOY ENVIRONMENT CONFIGURATION
# Economic Data Analytics Platform
# =============================================================================
# Copy this file to .env on your Dokploy server and fill in the values
# NEVER commit this file with real credentials!
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
DOMAIN=your-domain.com

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=economic_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!
POSTGRES_DB=economic_data

# -----------------------------------------------------------------------------
# ClickHouse Database
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_THIS_CLICKHOUSE_PASSWORD!
CLICKHOUSE_DB=economic_data

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD!
REDIS_DB=0

# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_MINIO_SECRET_KEY_MINIMUM_8_CHARS

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=GENERATE_A_SECURE_JWT_SECRET_KEY_HERE

# -----------------------------------------------------------------------------
# API Keys - Economic Data Sources
# -----------------------------------------------------------------------------
# FRED - Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# BEA - Get from: https://apps.bea.gov/api/signup/
BEA_API_KEY=your_bea_api_key

# Census - Get from: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key

# BLS - Get from: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key

# -----------------------------------------------------------------------------
# API Keys - Crypto Data Sources
# -----------------------------------------------------------------------------
# CoinGecko Pro (optional) - Get from: https://www.coingecko.com/api
COINGECKO_API_KEY=

# CryptoCompare - Get from: https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD!

# -----------------------------------------------------------------------------
# Airflow (Optional)
# -----------------------------------------------------------------------------
# Generate Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=GENERATE_FERNET_KEY_HERE
AIRFLOW_SECRET_KEY=GENERATE_AIRFLOW_SECRET_KEY_HERE
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_THIS_AIRFLOW_PASSWORD!

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Rate Limiting
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_PERIOD=60
